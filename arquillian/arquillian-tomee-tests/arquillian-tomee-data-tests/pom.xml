<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <artifactId>arquillian-tomee-tests</artifactId>
    <groupId>org.apache.tomee</groupId>
    <version>11.0.0-SNAPSHOT</version>
  </parent>

  <artifactId>arquillian-tomee-data-tests</artifactId>
  <name>TomEE :: Arquillian Adaptors Parent :: Tests :: Jakarta Data</name>

  <dependencies>
    <dependency>
      <groupId>${project.groupId}</groupId>
      <artifactId>openejb-jakarta-data</artifactId>
      <version>${project.version}</version>
      <scope>test</scope>
    </dependency>
    <!-- Hibernate annotation processor — generates Repository_ impl classes at compile time -->
    <dependency>
      <groupId>org.hibernate.orm</groupId>
      <artifactId>hibernate-processor</artifactId>
      <version>${version.hibernate.orm}</version>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <configuration>
          <annotationProcessorPaths>
            <path>
              <groupId>org.hibernate.orm</groupId>
              <artifactId>hibernate-processor</artifactId>
              <version>${version.hibernate.orm}</version>
            </path>
          </annotationProcessorPaths>
        </configuration>
      </plugin>
      <!--
        Remove Hibernate-generated JPA static metamodel classes (*_.class) from
        test-classes after compilation. These conflict with OpenJPA's runtime metamodel
        in embedded test mode. The Jakarta Data metamodel (_*) and repository impl
        (DataItemRepository_) are kept.
      -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-antrun-plugin</artifactId>
        <executions>
          <execution>
            <id>remove-jpa-metamodel</id>
            <phase>test-compile</phase>
            <goals>
              <goal>run</goal>
            </goals>
            <configuration>
              <target>
                <delete>
                  <fileset dir="${project.build.testOutputDirectory}">
                    <include name="**/SimpleItem_.class" />
                  </fileset>
                </delete>
              </target>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
</project>
